@echo off\nREM نسخة APK للتطبيق - Windows\nREM هذا السكريبت ينشئ APK جاهزة للتثبيت\n\necho 🔨 جاري بناء APK...\n\nREM التحقق من وجود Android SDK\nif \"%ANDROID_HOME%\"==\" \" (\n    echo ❌ خطأ: Android SDK غير مثبت\n    echo يرجى تثبيت Android Studio والـ SDK\n    exit /b 1\n)\n\nREM إنشاء مجلد Android إذا لم يكن موجوداً\nif not exist \"android\" (\n    echo 📱 جاري إنشاء مجلد Android...\n    call npx create-expo-app android\n)\n\nREM بناء APK\necho ⚙️ جاري بناء APK...\ncd android\ncall gradlew.bat assembleRelease\n\nif %errorlevel% equ 0 (\n    echo ✅ تم إنشاء APK بنجاح!\n    echo 📍 الملف موجود في: android\\app\\build\\outputs\\apk\\release\\\n) else (\n    echo ❌ فشل البناء\n    exit /b 1\n)